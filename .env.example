h# Server
PORT=5000
NODE_ENV=production

# JWT Secret — change this to a long random string!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database path (Railway uses ephemeral storage — use Railway Volume or external DB for persistence)
DB_PATH=./taskflow.db

# Frontend URL for CORS (optional, defaults to *)
CLIENT_URL=https://your-railway-app.up.railway.app
